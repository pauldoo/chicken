# OpenClaw secrets — copy to /etc/openclaw/secrets.env and fill in values.
# This file must be owned by root with mode 600.
# Never commit the real secrets.env to git.

# AWS credentials for Bedrock inference.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1

# OpenClaw gateway authentication token.
OPENCLAW_GATEWAY_TOKEN=
